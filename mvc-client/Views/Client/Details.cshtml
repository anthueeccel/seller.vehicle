@model ClientWithRoleViewModel

@{
    ViewData["Title"] = "Client Details";
}

<h1>Client Details</h1>

<div>
    <dl class="row">
        <dt class="col-sm-2">@Html.DisplayNameFor(m => m.Client.Id)</dt>
        <dd class="col-sm-10">@Model.Client.Id</dd>

        <dt class="col-sm-2">@Html.DisplayNameFor(m => m.Client.FirstName)</dt>
        <dd class="col-sm-10">@Model.Client.FirstName</dd>

        <dt class="col-sm-2">@Html.DisplayNameFor(m => m.Client.LastName)</dt>
        <dd class="col-sm-10">@Model.Client.LastName</dd>

        <dt class="col-sm-2">@Html.DisplayNameFor(m => m.Client.Email)</dt>
        <dd class="col-sm-10">@Model.Client.Email</dd>

        <dt class="col-sm-2">@Html.DisplayNameFor(m => m.Client.CountryPhoneCode)</dt>
        <dd class="col-sm-10">@Model.Client.CountryPhoneCode</dd>

        <dt class="col-sm-2">@Html.DisplayNameFor(m => m.Client.Phone)</dt>
        <dd class="col-sm-10">@Model.Client.Phone</dd>

        <dt class="col-sm-2">Role</dt>
        <dd class="col-sm-10">@(Model.Role.HasValue ? Model.Role.ToString() : "-")</dd>

    </dl>
</div>

<div>
    <a asp-action="Edit" asp-route-id="@Model.Client.Id" class="btn btn-warning">Edit</a>
    <a asp-action="Delete" asp-route-id="@Model.Client.Id" class="btn btn-danger">Delete</a>
    <a asp-action="Index" class="btn btn-secondary">Back to List</a>
</div>