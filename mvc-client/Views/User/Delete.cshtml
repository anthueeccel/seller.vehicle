@model UserViewModel

@{
    ViewData["Title"] = "Delete User";
}

<h1>Delete User</h1>

<div class="alert alert-danger">
    <h4>Are you sure you want to delete this user?</h4>
</div>

<div>
    <dl class="row">
        <dt class="col-sm-2">@Html.DisplayNameFor(m => m.User.Id)</dt>
        <dd class="col-sm-10">@Model.User.Id</dd>

        <dt class="col-sm-2">Client</dt>
        <dd class="col-sm-10">@Model.ClientFullName</dd>

        <dt class="col-sm-2">@Html.DisplayNameFor(m => m.User.Role)</dt>
        <dd class="col-sm-10">@Model.User.Role</dd>

        <dt class="col-sm-2">@Html.DisplayNameFor(m => m.User.IsActive)</dt>
        <dd class="col-sm-10">
            @if (Model.User.IsActive)
            {
                <span class="badge bg-success">Active</span>
            }
            else
            {
                <span class="badge bg-secondary">Inactive</span>
            }
        </dd>
    </dl>
</div>

<form asp-action="Delete" method="post">
    <input type="hidden" asp-for="User.Id" />
    <input type="submit" value="Delete" class="btn btn-danger" />
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>